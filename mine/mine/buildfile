libs =
import                       libs += libboost-asio%lib{boost_asio}
import                       libs += libfreetype%lib{freetype}
import                       libs += libicui18n%lib{icui18n}
import                       libs += libimmer%lib{immer}
import! [rule_hint=cxx.link] libs += lua%lib{lua}
import                       libs += glfw%lib{glfw}

exe{mine}: {hxx ixx txx cxx}{** -mine-version -mine-utility-*installed} \
           {hxx            }{    mine-version                         } \
           {h           c  }{**                                       } \
           $libs

# Link the appropriate utility object file depending on the build operation.
#
# If we are building for installation, we link the installed object file which
# contains the resolved absolute or relative installation paths. Otherwise, we
# link the uninstalled object file which maps data paths directly to the local
# source tree.
#
exe{mine}: cxx{mine-utility-installed}:   for_install = true
exe{mine}: cxx{mine-utility-uninstalled}: for_install = false

# Note that while the -installed object file should only be linked when we are
# installing, it will be compiled even in the uninstalled case.
#
# Note also the use of regex replacement in the path macros below. We must
# escape backslashes so they are not treated as C++ escape sequences when passed
# as string literals on the compiler command line. This is primarily necessary
# for Windows paths.
#
# For the uninstalled case, we map the data directory directly to the source
# directory. Note that we append the package directory since we are not a bare
# package. We keep this outside the install condition so local development
# builds always receive the correct path.
#
{obj obje}{mine-utility-uninstalled}: cxx.poptions += \
  -DMINE_INSTALL_DATA=\"$regex.replace($src_root/data, '\\', '\\\\')\"

# Configure the installed object file only if we are actually installing.
#
ifn! $install.root
{
  # Resolve the data installation directory. If the installation is relocatable,
  # resolve it against the executable directory so the program can find its data
  # dynamically at runtime. Otherwise, resolve it as a standard absolute path.
  #
  {obj obje}{mine-utility-installed}: cxx.poptions += \
    -DMINE_INSTALL_DATA=\"$regex.replace(\
      $install.resolve($install.data, \
                       $install.relocatable ? $install.bin : [dir_path]), \
      '\\', \
      '\\\\')\"

  # Handle relocatable installations.
  #
  # If relocatable, the executable might be moved post-installation. We provide
  # the base install root and the relative path from the executable back to the
  # root.
  #
  if $install.relocatable
  {
    {obj obje}{mine-utility-installed}: cxx.poptions += \
      -DMINE_INSTALL_ROOT=\"$regex.replace($install.root, '\\', '\\\\')\"

    {obj obje}{mine-utility-installed}: cxx.poptions += \
      -DMINE_INSTALL_ROOT_RELATIVE=\"$regex.replace(\
        $path.relative($install.root, \
                       $install.resolve($install.bin, [dir_path])), \
        '\\', \
        '\\\\')\"
  }
}

# Version header generation.
#
hxx{mine-version}: in{mine-version} $src_root/manifest

# Build options.
#
cc.poptions =+ "-I$out_root" "-I$src_root"
